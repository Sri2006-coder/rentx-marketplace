generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ENUMS
enum Role {
  USER
  ADMIN
}

enum ItemStatus {
  ACTIVE
  INACTIVE
  HIDDEN
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CONFIRMED
  ACTIVE
  RETURNED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  ESCROW_HELD
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CARD
  UPI
  MOCK
}

enum DamageReport {
  NONE
  MINOR
  MAJOR
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

// MODELS
model User {
  id           String   @id @default(uuid())
  firstName    String
  lastName     String
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  status       UserStatus @default(ACTIVE)
  profileImage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items           Item[]         @relation("UserItems")
  bookings        Booking[]      @relation("UserBookings")
  wishlists       Wishlist[]
  auditLogs       AuditLog[]
  reviewsGiven    Review[]       @relation("ReviewsGiven")
  reviewsReceived Review[]       @relation("ReviewsReceived")
  trustProfile    TrustProfile?
  payments        Payment[]
  disputesFiled         Dispute[]      @relation("DisputesFiled")
  disputesAgainst       Dispute[]      @relation("DisputesAgainst")
  conversationsAsOwner  Conversation[] @relation("ConversationsAsOwner")
  conversationsAsRenter Conversation[] @relation("ConversationsAsRenter")
  messagesSent          Message[]      @relation("MessagesSent")
  notifications         Notification[]
}

model Item {
  id              String     @id @default(uuid())
  ownerId         String
  title           String
  description     String
  dailyRate       Decimal
  securityDeposit Decimal
  category        String
  condition       String
  city            String
  state           String?
  status          ItemStatus @default(ACTIVE)
  requireVerified Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  owner           User           @relation("UserItems", fields: [ownerId], references: [id], onDelete: Cascade)
  images          ItemImage[]
  bookings        Booking[]
  wishlists       Wishlist[]
  availabilities  Availability[]
  reviews         Review[]
  conversations   Conversation[]

  @@index([category])
  @@index([ownerId])
  @@index([status])
}

model ItemImage {
  id        String   @id @default(uuid())
  itemId    String
  imageUrl  String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model Booking {
  id               String        @id @default(uuid())
  itemId           String
  renterId         String
  startDate        DateTime
  endDate          DateTime
  totalPrice       Decimal
  status           BookingStatus @default(PENDING)
  actualReturnDate DateTime?
  lateFee          Decimal?
  notes            String?
  damageReport     DamageReport?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  item             Item          @relation(fields: [itemId], references: [id])
  renter           User          @relation("UserBookings", fields: [renterId], references: [id])
  reviews          Review[]
  payments         Payment[]
  disputes         Dispute[]

  @@index([itemId])
  @@index([renterId])
  @@index([status])
  @@index([startDate, endDate])
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  itemId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId])
}

model Availability {
  id          String   @id @default(uuid())
  itemId      String
  blockedFrom DateTime
  blockedTo   DateTime
  reason      String?

  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([blockedFrom, blockedTo])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String   
  entityType String   
  entityId   String
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([userId])
}

model Review {
  id          String   @id @default(uuid())
  bookingId   String
  itemId      String
  reviewerId  String
  revieweeId  String
  rating      Int
  comment     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  reviewer    User     @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee    User     @relation("ReviewsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)

  @@unique([bookingId, reviewerId])
  @@index([itemId])
  @@index([reviewerId])
  @@index([revieweeId])
}

model TrustProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  aadhaarUrl      String?
  panUrl          String?
  aadhaarStatus   String   @default("UNVERIFIED")
  panStatus       String   @default("UNVERIFIED")
  emailVerified   Boolean  @default(false)
  phoneVerified   Boolean  @default(false)
  trustScore      Int      @default(0)
  verifiedBadge   Boolean  @default(false)
  selfieUrl       String?
  faceMatchScore  Float?
  ocrText         String?
  verifiedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String        @id @default(uuid())
  bookingId       String
  renterId        String
  amount          Decimal
  securityDeposit Decimal
  totalAmount     Decimal
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   PaymentMethod @default(MOCK)
  transactionId   String?       @unique
  paidAt          DateTime?
  refundedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  booking         Booking       @relation(fields: [bookingId], references: [id])
  renter          User          @relation(fields: [renterId], references: [id])

  @@index([bookingId])
  @@index([renterId])
  @@index([paymentStatus])
}

model Dispute {
  id          String        @id @default(uuid())
  bookingId   String
  filerId     String
  againstId   String
  description String
  evidenceUrl String?
  status      DisputeStatus @default(OPEN)
  resolution  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  booking     Booking       @relation(fields: [bookingId], references: [id])
  filer       User          @relation("DisputesFiled", fields: [filerId], references: [id])
  against     User          @relation("DisputesAgainst", fields: [againstId], references: [id])

  @@index([bookingId])
  @@index([filerId])
  @@index([status])
}

model Conversation {
  id        String   @id @default(uuid())
  ownerId   String
  renterId  String
  itemId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner    User      @relation("ConversationsAsOwner", fields: [ownerId], references: [id])
  renter   User      @relation("ConversationsAsRenter", fields: [renterId], references: [id])
  item     Item?     @relation(fields: [itemId], references: [id])
  messages Message[]

  @@index([ownerId])
  @@index([renterId])
  @@index([itemId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessagesSent", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
